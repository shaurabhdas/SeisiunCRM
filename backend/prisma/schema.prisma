datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  company   String?
  status    String   // "Lead" | "MQL" | "SQL" | "Customer" | "Churned"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals        Deal[]
  tasks        Task[]
  activityLogs ActivityLog[]
}

model Deal {
  id                String    @id @default(uuid())
  name              String
  value             Float
  stage             String    // "Lead" | "Contacted" | "Demo" | "Proposal" | "Negotiation" | "Closed Won" | "Closed Lost"
  priority          String    // "Low" | "Medium" | "High"
  expectedCloseDate DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Forecast Pulse Fields
  pushedCount       Int       @default(0)
  stageChangedAt    DateTime  @default(now())
  description       String?
  nextAction        String?
  manualProbability Int?
  overrideRiskFlag  Boolean   @default(false)
  customRiskText    String?

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model StageWeight {
  stage       String   @id
  probability Float
}

model DealSnapshot {
  id                String    @id @default(uuid())
  dealId            String
  name              String
  value             Float
  stage             String
  expectedCloseDate DateTime?
  snapshotDate      DateTime  @default(now())
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    // "Pending" | "Completed"
  priority    String    // "Low" | "Medium" | "High"
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id        String   @id @default(uuid())
  type      String   // "Call" | "Email" | "Meeting" | "Note"
  content   String
  createdAt DateTime @default(now())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Account {
  id          String   @id @default(uuid())
  name        String
  industry    String?
  companySize String?  @map("company_size")
  salesRegion String?  @map("sales_region")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  leads       Lead[]
  contacts    LeadContact[]

  @@map("accounts")
}

model Lead {
  id                     String   @id @default(uuid())
  opportunityName        String   @map("opportunity_name")
  accountId              String?  @map("account_id")
  account                Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  stage                  String   @default("contact") // contact, outreach, connected, presentation, demo, evaluating, disqualified
  openDate               DateTime? @default(now()) @db.Date @map("open_date")
  forecastCloseDate      DateTime? @db.Date @map("forecast_close_date")
  painPoints             String?  @map("pain_points")
  competitor             String?
  lastConnectDate        DateTime? @db.Date @map("last_connect_date")
  assignedRepId          String?  @map("assigned_rep_id") // UUID references auth.users(id)
  disqualificationReason String?  @map("disqualification_reason") // no_budget, no_authority, etc.
  postDemoOutcome        String?  @map("post_demo_outcome") // proposal_requested, pilot_agreed, etc.
  dealValue              Decimal? @default(0) @db.Decimal(12, 2) @map("deal_value")
  createdAt              DateTime @default(now()) @map("created_at")

  contacts               LeadContact[]
  activities             LeadActivity[]
  stageHistory           LeadStageHistory[]

  @@map("leads")
}

model LeadContact {
  id              String   @id @default(uuid())
  leadId          String?  @map("lead_id")
  lead            Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  accountId       String?  @map("account_id")
  account         Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  email           String?
  phone           String?
  stakeholderRole String?  @map("stakeholder_role")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("contacts")
}

model LeadActivity {
  id           String   @id @default(uuid())
  leadId       String?  @map("lead_id")
  lead         Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  activityType String   @map("activity_type") // email, call, meeting, presentation, demo
  activityDate DateTime? @default(now()) @db.Date @map("activity_date")
  note         String?
  loggedBy     String?  @map("logged_by") // UUID references auth.users(id)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("lead_activities")
}

model LeadStageHistory {
  id        String   @id @default(uuid())
  leadId    String?  @map("lead_id")
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStage String?  @map("from_stage")
  toStage   String   @map("to_stage")
  changedAt DateTime @default(now()) @map("changed_at")
  changedBy String?  @map("changed_by") // UUID references auth.users(id)

  @@map("lead_stage_history")
}
